{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ComicFlow",
  "version": "0.1.0",
  "identifier": "com.comicflow.desktop",
  "build": {
    "frontendDist": "../app",
    "beforeDevCommand": "python3 -m http.server 1420 --directory app",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "ComicFlow",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
